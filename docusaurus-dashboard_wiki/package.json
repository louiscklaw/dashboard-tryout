{
  "name": "wiki",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start --host=0.0.0.0",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "lint:format": "prettier --write **/*.{js,jsx}",
    "gitSync": "git fetch --all && git stash && git pull && git stash pop",
    "gitUpdate": "git add . && git commit -m\"update wiki,\" && yarn gitSync && git push",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "deploy_firebase": "npm run clear && npx rimraf .firebase && npm run build && firebase deploy",
    "deploy_gh_pages": "npm run clear && npm run build && gh-pages -d build",
    "deploy_all": "yarn deploy_firebase && yarn deploy_gh_pages",
    "husky_install": "husky install",
    "docker_rebuild": "docker compose up -d --build",
    "into_docker": "docker compose exec -it tests_host bash"
  },
  "dependencies": {
    "@docusaurus/core": "^2.1.0",
    "@docusaurus/module-type-aliases": "^2.1.0",
    "@docusaurus/preset-classic": "^2.1.0",
    "@easyops-cn/docusaurus-search-local": "^0.23.2",
    "@emotion/react": "^11.9.3",
    "@emotion/styled": "^11.9.3",
    "@mdx-js/react": "^1.6.22",
    "@mui/icons-material": "^5.10.6",
    "@mui/material": "^5.8.7",
    "clsx": "^1.1.1",
    "husky": "^8.0.1",
    "lodash": "^4.17.21",
    "plugin-image-zoom": "^1.1.0",
    "prettier": "latest",
    "prism-react-renderer": "^1.3.1",
    "puppeteer": "latest",
    "react": "^17.0.2",
    "react-div-100vh": "^0.7.0",
    "react-dom": "^17.0.2",
    "react-json-to-table": "^0.1.7",
    "rimraf": "^3.0.2"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "gh-pages": "^4.0.0"
  }
}
