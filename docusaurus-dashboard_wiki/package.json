{
  "name": "wiki",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "gitUpdate": "git add . && git commit -m\"update wiki,\" && git push",
    "lint:format": "prettier --write **/*.{js,jsx,ts,tsx}",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "deploy_firebase": "yarn clear && yarn rimraf .firebase && yarn build && firebase deploy",
    "deploy_gh_pages": "yarn clear && yarn build && gh-pages -d build",
    "husky_install": "husky install"
  },
  "dependencies": {
    "@docusaurus/core": "2.0.0-beta.19",
    "@docusaurus/module-type-aliases": "2.0.0-beta.19",
    "@docusaurus/preset-classic": "2.0.0-beta.19",
    "@easyops-cn/docusaurus-search-local": "^0.23.2",
    "@emotion/react": "^11.9.3",
    "@emotion/styled": "^11.9.3",
    "@mdx-js/react": "^1.6.22",
    "@mui/material": "^5.8.7",
    "clsx": "^1.1.1",
    "husky": "^8.0.1",
    "plugin-image-zoom": "github:flexanalytics/plugin-image-zoom",
    "prettier": "latest",
    "prism-react-renderer": "^1.3.1",
    "puppeteer": "latest",
    "react": "^17.0.2",
    "react-div-100vh": "^0.7.0",
    "react-dom": "^17.0.2",
    "react-json-to-table": "^0.1.7",
    "rimraf": "^3.0.2"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
